{
  "name": "kashmir-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bunx --bun astro check && bunx --bun astro build",
    "check": "bunx --bun astro check",
    "deploy": "bunx wrangler deploy",
    "dev": "bunx --bun astro dev",
    "format": "oxfmt --write .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:prod": "knip --production",
    "lhci": "lhci autorun",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepare": "lefthook install",
    "preview": "bunx --bun astro preview"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/sitemap": "^3.7.2",
    "@nanostores/persistent": "^1.3.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.7",
    "astro-icon": "^1.1.5",
    "nanostores": "^1.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@lhci/cli": "^0.15.1",
    "knip": "^5.88.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.60.0",
    "sort-package-json": "^3.6.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0"
  }
}
